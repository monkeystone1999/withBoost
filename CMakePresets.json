{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "description": "팀 공통 기본 빌드 설정 (Ninja 및 vcpkg)",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "Qt6_DIR": "$env{Qt6_DIR}",
        "CMAKE_PREFIX_PATH": "$env{Qt6_ROOT}"
      }
    },
    {
      "name": "default-debug",
      "displayName": "팀 공유 Debug",
      "description": "공통 표준 Debug 빌드 옵션",
      "inherits": "default-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "default-release",
      "displayName": "팀 공유 Release",
      "description": "공통 표준 Release 빌드 옵션",
      "inherits": "default-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-debug",
      "configurePreset": "default-debug"
    },
    {
      "name": "default-release",
      "configurePreset": "default-release"
    }
  ]
}